<div class="app-shell">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-icon">
        <i class="bi bi-rocket-takeoff-fill"></i>
      </div>
      <div class="brand-text">
        <div class="brand-title">KanbanPro</div>
        <div class="brand-sub">Sprint Board</div>
      </div>
    </div>

    <nav class="sidebar-nav">
      <a class="nav-item active" href="/dashboard">
        <i class="bi bi-speedometer2"></i>
        <span>Dashboard</span>
      </a>
      <a class="nav-item" href="#">
        <i class="bi bi-list-check"></i>
        <span>Tareas</span>
      </a>
      <a class="nav-item" href="#">
        <i class="bi bi-bug"></i>
        <span>Incidencias</span>
      </a>
      <a class="nav-item" href="#">
        <i class="bi bi-people"></i>
        <span>Equipo</span>
      </a>
      <a class="nav-item" href="#">
        <i class="bi bi-gear"></i>
        <span>Configuración</span>
      </a>
    </nav>

    <div class="sidebar-footer">
      <a class="sidebar-logout" href="/login">
        <i class="bi bi-box-arrow-left"></i>
        <span>Cerrar sesión</span>
      </a>
    </div>
  </aside>

  <!-- OVERLAY SIDEBAR MOBILE -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- MAIN -->
  <main class="main">

    <!-- TOP BAR -->
    <div class="topbar">
      <div class="topbar-left">
        <button
          class="topbar-icon-btn d-lg-none"
          type="button"
          id="sidebarToggle"
          aria-label="Abrir menú"
        >
          <i class="bi bi-list"></i>
        </button>
        <div class="page-title">
          <div class="title">{{board.name}}</div>
          <div class="subtitle">Panel de gestión de tareas</div>
        </div>
      </div>

      <div class="topbar-right">
        <button
          class="topbar-icon-btn"
          type="button"
          disabled
          aria-label="Notificaciones"
        >
          <i class="bi bi-bell"></i>
        </button>
        <button
          class="topbar-icon-btn"
          type="button"
          disabled
          aria-label="Ayuda"
        >
          <i class="bi bi-question-circle"></i>
        </button>
        <div class="topbar-avatar" aria-label="Usuario">
          <i class="bi bi-person-fill"></i>
        </div>
      </div>
    </div>

    <!-- TABS -->
    <div class="tabsbar">
      <a class="tab-item active" href="#">
        <i class="bi bi-grid"></i>
        <span>Dashboard</span>
      </a>
      <a class="tab-item" href="#">
        <i class="bi bi-list-check"></i>
        <span>Tareas</span>
      </a>
      <a class="tab-item" href="#">
        <i class="bi bi-bug"></i>
        <span>Incidencias</span>
      </a>
      <a class="tab-item" href="#">
        <i class="bi bi-bar-chart"></i>
        <span>Reportes</span>
      </a>
    </div>

    <!-- SUBBAR -->
    <div class="subbar">
      <div class="filters">
        <div class="filter-chip">
          <i class="bi bi-funnel"></i>
          <select
            class="filter-select"
            disabled
            aria-label="Filtro por prioridad"
          >
            <option>Prioridad: Todas</option>
            <option>Alta</option>
            <option>Media</option>
            <option>Baja</option>
          </select>
        </div>

        <div class="filter-chip">
          <i class="bi bi-person"></i>
          <input
            class="filter-input"
            placeholder="Asignada a..."
            disabled
            aria-label="Filtro por usuario"
          />
        </div>

        <div class="filter-chip">
          <i class="bi bi-calendar3"></i>
          <input
            class="filter-input"
            type="date"
            disabled
            aria-label="Filtro por fecha"
          />
        </div>
      </div>

      <div class="subbar-actions">
        <button class="dash-btn-primary" type="button" id="openCreateTask">
          <i class="bi bi-plus-circle"></i>
          Crear tarea
        </button>
      </div>
    </div>

    <!-- KANBAN -->
    <div class="kanban-wrap">
      <div class="kanban-board">
        {{#each board.lists}}
          <section class="kanban-col" data-list-id="{{this.id}}">
            <div class="col-head">
              <div class="col-title">
                <span class="col-dot"></span>
                <span class="col-name">{{this.title}}</span>
              </div>
              <span class="count-badge" data-count>{{this.cards.length}}</span>
            </div>

            <div class="kanban-col-body" data-list-id="{{this.id}}">
              {{#if this.cards.length}}
                {{#each this.cards}}
                  <div
                    class="task-card"
                    draggable="true"
                    data-card-id="{{this.id}}"
                    data-priority="{{this.priority}}"
                    data-assignee="{{this.assignee}}"
                    data-due="{{this.dueDate}}"
                  >
                    <div class="task-top">
                      <span class="task-id">
                        {{#if
                          this.publicId
                        }}{{this.publicId}}{{else}}{{this.id}}{{/if}}
                      </span>
                      <div class="task-avatar" aria-label="Asignado">
                        <i class="bi bi-person-fill"></i>
                      </div>
                    </div>

                    <div class="task-title">{{this.title}}</div>
                    <div class="task-desc">{{this.description}}</div>

                    <div class="task-bottom">
                      <span
                        class="pill pill-{{this.priority}}"
                      >{{this.priority}}</span>
                      <span
                        class="task-date"
                        data-due="{{this.dueDate}}"
                      >{{this.dueDate}}</span>
                    </div>
                  </div>
                {{/each}}
              {{else}}
                <div class="empty-col">Sin tareas por ahora.</div>
              {{/if}}
            </div>
          </section>
        {{/each}}
      </div>
    </div>

  </main>
</div>

<!-- ===== MODAL CREAR TAREA ===== -->
<div class="modal-overlay" id="modalOverlay" aria-hidden="true">
  <div
    class="modal-card"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modalTitle"
  >

    <div class="modal-card-head">
      <div class="modal-card-title-wrap">
        <div class="modal-card-icon">
          <i class="bi bi-plus-circle-fill"></i>
        </div>
        <div>
          <h2 class="modal-card-title" id="modalTitle">Nueva tarea</h2>
          <p class="modal-card-sub">Se creará en la columna
            <strong>Por hacer</strong></p>
        </div>
      </div>
      <button class="modal-close" id="closeModal" aria-label="Cerrar">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <form method="POST" action="/tareas" class="modal-card-body">
      <div class="modal-grid">

        <div class="modal-field modal-field-full">
          <label class="modal-label">Título
            <span class="modal-required">*</span></label>
          <input
            class="modal-control"
            name="title"
            maxlength="60"
            placeholder="Ej: Diseñar pantalla de login"
            required
          />
        </div>

        <div class="modal-field">
          <label class="modal-label">Asignada a
            <span class="modal-required">*</span></label>
          <div class="modal-input-wrap">
            <i class="bi bi-person modal-input-icon"></i>
            <input
              class="modal-control modal-control-icon"
              name="assignee"
              maxlength="40"
              placeholder="Nombre del responsable"
              required
            />
          </div>
        </div>

        <div class="modal-field">
          <label class="modal-label">Fecha límite
            <span class="modal-required">*</span></label>
          <div class="modal-input-wrap">
            <i class="bi bi-calendar3 modal-input-icon"></i>
            <input
              class="modal-control modal-control-icon"
              type="date"
              name="dueDate"
              required
            />
          </div>
        </div>

        <div class="modal-field modal-field-full">
          <label class="modal-label">Prioridad</label>
          <div class="modal-priority-group">
            <label class="priority-opt priority-high">
              <input type="radio" name="priority" value="Alta" />
              <i class="bi bi-arrow-up-circle-fill"></i>
              Alta
            </label>
            <label class="priority-opt priority-med">
              <input type="radio" name="priority" value="Media" checked />
              <i class="bi bi-dash-circle-fill"></i>
              Media
            </label>
            <label class="priority-opt priority-low">
              <input type="radio" name="priority" value="Baja" />
              <i class="bi bi-arrow-down-circle-fill"></i>
              Baja
            </label>
          </div>
        </div>

        <div class="modal-field modal-field-full">
          <label class="modal-label">Descripción</label>
          <textarea
            class="modal-control"
            name="description"
            rows="3"
            maxlength="140"
            placeholder="Descripción breve de la tarea..."
          ></textarea>
        </div>

      </div>

      <div class="modal-card-foot">
        <button
          type="button"
          class="dash-btn-ghost"
          id="cancelModal"
        >Cancelar</button>
        <button type="submit" class="dash-btn-primary">
          <i class="bi bi-check2-circle"></i>
          Crear tarea
        </button>
      </div>
    </form>

  </div>
</div>

<script src="/js/kanban-dnd.js"></script>
<script src="/js/sidebar.js"></script>
<script>
  var modalOverlay = document.getElementById('modalOverlay'); function
  abrirModal() { modalOverlay.style.display = 'flex'; } function cerrarModal() {
  modalOverlay.style.display = 'none'; }
  document.getElementById('openCreateTask').onclick = abrirModal;
  document.getElementById('closeModal').onclick = cerrarModal;
  document.getElementById('cancelModal').onclick = cerrarModal;
  modalOverlay.onclick = function(e) { if (e.target === modalOverlay)
  cerrarModal(); }; document.onkeydown = function(e) { if (e.key === 'Escape')
  cerrarModal(); };
</script>