<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>KanbanPro</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/main.css" />
  </head>

  <body>
    <!-- NAVBAR -->
    <nav class="app-nav">
      <div class="container">
        <div class="nav-inner">
          <a class="nav-brand" href="/">
            <i class="bi bi-rocket-takeoff-fill nav-brand-icon"></i>
            <span>KanbanPro</span>
          </a>

          <button
            class="nav-toggler"
            id="navToggler"
            aria-label="Abrir menú"
            aria-expanded="false"
          >
            <span></span>
            <span></span>
            <span></span>
          </button>

          <div class="nav-links" id="navLinks">
            <a class="nav-link-item" href="/">Inicio</a>
            <a class="nav-link-item" href="/login">Iniciar sesión</a>
            <a class="nav-cta" href="/register">Registrarse</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- CONTENIDO PRINCIPAL — sin container, cada sección lo maneja -->
    <main>
      {{{body}}}
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="container">

        <div class="footer-top">

          <!-- Marca -->
          <div class="footer-brand-col">
            <a class="footer-brand" href="/">
              <i class="bi bi-rocket-takeoff-fill"></i>
              <span>KanbanPro</span>
            </a>
            <p class="footer-desc">
              Organiza tareas, controla el flujo de trabajo y da seguimiento a
              cada sprint con un tablero Kanban simple y eficiente.
            </p>
            <div class="footer-social">
              <a href="#" aria-label="GitHub"><i class="bi bi-github"></i></a>
              <a href="#" aria-label="LinkedIn"><i
                  class="bi bi-linkedin"
                ></i></a>
              <a href="#" aria-label="Twitter/X"><i
                  class="bi bi-twitter-x"
                ></i></a>
            </div>
          </div>

          <!-- Producto -->
          <div class="footer-col">
            <h4 class="footer-col-title">Producto</h4>
            <ul class="footer-col-links">
              <li><a href="/dashboard">Dashboard</a></li>
              <li><a href="#">Tableros</a></li>
              <li><a href="#">Tareas</a></li>
              <li><a href="#">Sprints</a></li>
            </ul>
          </div>

          <!-- Cuenta -->
          <div class="footer-col">
            <h4 class="footer-col-title">Cuenta</h4>
            <ul class="footer-col-links">
              <li><a href="/register">Registrarse</a></li>
              <li><a href="/login">Iniciar sesión</a></li>
              <li><a href="#">Mi perfil</a></li>
            </ul>
          </div>

          <!-- Proyecto -->
          <div class="footer-col">
            <h4 class="footer-col-title">Proyecto</h4>
            <ul class="footer-col-links">
              <li><a href="#">Documentación</a></li>
              <li><a href="#">GitHub</a></li>
              <li><a href="#">Soporte</a></li>
            </ul>
          </div>

        </div>

        <div class="footer-bottom">
          <span class="footer-copy">© 2026 KanbanPro. Todos los derechos
            reservados.</span>
        </div>

      </div>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
    <script>
      const toggler = document.getElementById('navToggler'); const links =
      document.getElementById('navLinks'); if (toggler && links) {
      toggler.addEventListener('click', () => { const open =
      links.classList.toggle('open'); toggler.setAttribute('aria-expanded',
      open); toggler.classList.toggle('active', open); }); }
    </script>
  </body>
</html>