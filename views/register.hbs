<div class="auth-outer">
  <div class="auth-frame">

    <!-- IZQUIERDA — formulario -->
    <section class="auth-left">
      <a class="auth-brand" href="/">
        <i class="bi bi-rocket-takeoff-fill"></i>
        <span>KanbanPro</span>
      </a>

      <div class="auth-form-wrap">
        <p class="auth-kicker">Comienza tu experiencia</p>
        <h1 class="auth-title">Crear cuenta</h1>

        {{#if error}}
          <div class="auth-error">
            <i class="bi bi-exclamation-circle"></i>
            {{error}}
          </div>
        {{/if}}

        <form method="POST" action="/api/auth/register">
          <div class="mb-3">
            <label class="auth-label">Nombre completo</label>
            <div class="auth-input-wrap">
              <i class="bi bi-person auth-input-icon"></i>
              <input
                class="auth-control"
                type="text"
                name="nombre"
                placeholder="Tu nombre"
                required
              />
            </div>
          </div>

          <div class="mb-3">
            <label class="auth-label">Correo electrónico</label>
            <div class="auth-input-wrap">
              <i class="bi bi-envelope auth-input-icon"></i>
              <input
                class="auth-control"
                type="email"
                name="email"
                placeholder="ejemplo@email.com"
                required
              />
            </div>
          </div>

          <div class="mb-4">
            <label class="auth-label">Contraseña</label>
            <div class="auth-input-wrap">
              <i class="bi bi-lock auth-input-icon"></i>
              <input
                class="auth-control"
                type="password"
                name="password"
                placeholder="Mínimo 8 caracteres"
                required
                minlength="8"
              />
            </div>
          </div>

          <button class="auth-btn" type="submit">Crear cuenta gratis</button>

          <div class="auth-divider">
            <span>o registrarse con</span>
          </div>

          <div class="auth-social">
            <button
              class="auth-social-btn"
              type="button"
              disabled
              aria-label="Google"
            >
              <i class="bi bi-google"></i>
            </button>
            <button
              class="auth-social-btn"
              type="button"
              disabled
              aria-label="GitHub"
            >
              <i class="bi bi-github"></i>
            </button>
            <button
              class="auth-social-btn"
              type="button"
              disabled
              aria-label="Apple"
            >
              <i class="bi bi-apple"></i>
            </button>
          </div>

          <p class="auth-foot">
            ¿Ya tienes cuenta?
            <a class="auth-link" href="/login">Iniciar sesión</a>
          </p>
        </form>
      </div>
    </section>

    <!-- DERECHA — panel de marca -->
    <aside class="auth-right" aria-hidden="true">
      <div class="auth-right-inner">

        <div class="auth-right-logo">
          <i class="bi bi-rocket-takeoff-fill"></i>
        </div>

        <h2 class="auth-right-title">
          Tu primer sprint<br />empieza hoy.
        </h2>

        <p class="auth-right-desc">
          Crea tu cuenta en segundos y accede a un tablero Kanban listo para
          organizar tu trabajo desde el primer día.
        </p>

        <div class="auth-features">
          <div class="auth-feature">
            <div class="auth-feature-icon">
              <i class="bi bi-lightning-charge-fill"></i>
            </div>
            <div>
              <p class="auth-feature-title">Listo en minutos</p>
              <p class="auth-feature-desc">Sin configuración, sin complicaciones</p>
            </div>
          </div>

          <div class="auth-feature">
            <div class="auth-feature-icon">
              <i class="bi bi-people-fill"></i>
            </div>
            <div>
              <p class="auth-feature-title">Para equipos y solos</p>
              <p class="auth-feature-desc">Freelancers, estudiantes y equipos</p>
            </div>
          </div>

          <div class="auth-feature">
            <div class="auth-feature-icon">
              <i class="bi bi-shield-check"></i>
            </div>
            <div>
              <p class="auth-feature-title">Gratis para empezar</p>
              <p class="auth-feature-desc">Sin tarjeta de crédito requerida</p>
            </div>
          </div>
        </div>

      </div>
    </aside>

  </div>
</div>